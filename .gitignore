# 1. 绝对机密（防盗刷）
.env

# 2. Python 运行环境与缓存（体积巨大，毫无用处）
.venv/
__pycache__/
*.pyc

# 3. 向量数据库缓存（几十上百MB，绝对不能传网盘/GitHub）
chroma_db/

# 4. 重点来了！AI 自动生成的垃圾区（隐身术）
workspace/

# 5. 运行时数据
data/
temp_execution.py

# 6. AI 生成的代码输出（DP: 不推远程，仅本地保留）
generated_code/

# 7. 其他临时文件
*.html
!frontend/index.html

# 8. 前端构建产物
frontend/dist/
frontend/node_modules/
