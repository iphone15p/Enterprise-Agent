# ==========================================
# Enterprise Agent System — Environment Config
# ==========================================
# Copy this file to .env and fill in your values.

# DashScope API Key (get one at https://dashscope.console.aliyun.com/)
API_KEY=your_api_key_here

# DashScope compatible endpoint
BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Model name: qwen-plus (recommended), qwen-max, qwen-turbo
MODEL_NAME=qwen-plus

# Auth token for the frontend → backend API
AUTH_TOKEN=your_custom_token_here
